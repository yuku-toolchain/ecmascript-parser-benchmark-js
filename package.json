{
  "name": "ecmascript-parser-benchmark-js",
  "type": "module",
  "private": true,
  "scripts": {
    "bench": "bun scripts/load-files.ts && bun scripts/bench.ts && bun readme",
    "bench:typescript": "bun scripts/bench.ts typescript",
    "bench:calcom": "bun scripts/bench.ts calcom",
    "bench:react": "bun scripts/bench.ts react",
    "readme": "bun scripts/generate-readme.ts",
    "update-parsers": "bun update --latest --force",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@swc/core": "^1.15.33",
    "acorn": "^8.16.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "oxc-parser": "^0.128.0",
    "tinybench": "^6.0.1",
    "yuku-parser": "^0.5.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260504.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
