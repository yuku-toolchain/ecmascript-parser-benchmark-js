{
  "name": "ecmascript-parser-benchmark-js",
  "type": "module",
  "private": true,
  "scripts": {
    "bench": "bun scripts/load-files.ts && bun scripts/bench.ts && bun readme",
    "bench:typescript": "bun scripts/bench.ts typescript",
    "bench:checker": "bun scripts/bench.ts checker",
    "bench:react": "bun scripts/bench.ts react",
    "readme": "bun scripts/generate-readme.ts",
    "update-parsers": "bun update --latest --force",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^8.0.4",
    "@swc/core": "^1.15.46",
    "acorn": "^8.17.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "oxc-parser": "^0.141.0",
    "tinybench": "^6.0.2",
    "yuku-parser": "^0.7.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  }
}
